# 服务监听地址
WHISPERVIDEO_HOST=127.0.0.1
WHISPERVIDEO_PORT=8000

# 工作目录
WHISPERVIDEO_WORKSPACE=workspace

# Whisper 所使用的 Python 路径
# 示例：D:\tools\python\python.exe
WHISPERVIDEO_WHISPER_PYTHON=D:\path\to\python.exe

# Whisper 模型
# 可填写模型名称，例如 small / medium
# 也可以直接填写模型文件路径
WHISPERVIDEO_WHISPER_MODEL=D:\path\to\models\small.pt

# Whisper 模型目录，可留空
WHISPERVIDEO_WHISPER_MODEL_DIR=D:\path\to\models

# 转写语言，例如 zh / en
WHISPERVIDEO_WHISPER_LANGUAGE=en

# ffmpeg 可执行文件路径
# 示例：D:\tools\ffmpeg\bin\ffmpeg.exe
WHISPERVIDEO_FFMPEG_BIN=D:\path\to\ffmpeg\bin\ffmpeg.exe
